# Telegram
BOT_TOKEN=
OWNER_ID=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Local destination
LOCAL_DOWNLOAD_ROOT=/media

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=

# BuzzHeavier
# Optional. If empty, BuzzHeavier uploads are attempted anonymously.
BUZZHEAVIER_ACCOUNT_ID=

# Tasks
TASK_LIMIT=10

# Status
STATUS_UPDATE_INTERVAL=10

# Temporary Web UI
# Torrent selector opens on TORRENT_SELECTION_PORT.
# Google Drive search pages open on TORRENT_SELECTION_PORT + 1.
# Public links auto-detect the VPS IP. Optional emergency override: PUBLIC_BASE_URL=http://your-server-ip:8000
TORRENT_SELECTION_PORT=8000
TORRENT_SELECTION_TIMEOUT=300
TZ=Asia/Kolkata

# Media integrations
JELLYFIN_API_KEY=
TMDB_API_KEY=
